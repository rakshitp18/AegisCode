.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iws
*.iml
*.ipr
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# --- Logs and Diagnostics ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment Variables and Secrets ---
.env
.env.local
.env.*.local
*.env

# --- Node / Frontend (React/Vite) ---
node_modules/
dist/
dist-ssr/
*.local

# --- Python (backend_python) ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/
.venv/
.pytest_cache/
.tox/
.coverage
htmlcov/

# --- Java / Maven (backend) ---
target/
build/
**/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/
*.class
HELP.md

# --- Project Temp / Output Directories ---
uploads/
reports/
